page {
  background: linear-gradient(180deg, #fff8fb 0%, #fefaf3 48%, #f6fbff 100%);
  color: #5f4b53;
  font-size: 28rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid #ffe3ef;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 174, 204, 0.16);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #ff6fa0;
}

.subtitle {
  color: #9a7f8b;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #ff8eb5, #ffa6cb);
  color: #fff;
  border-radius: 999rpx;
  font-weight: 600;
}
